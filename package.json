{
  "name": "hono-drizzle-task-api",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docker:dev:up": "docker compose -f docker-compose.dev.yaml up",
    "docker:dev:down": "docker compose -f docker-compose.dev.yaml down",
    "test": "dotenv -e .env.test -- vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.0",
    "@scalar/hono-api-reference": "^0.9.40",
    "dotenv": "^17.2.4",
    "dotenv-expand": "^12.0.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.11.7",
    "hono-pino": "^0.10.3",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.16.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.3.1",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
